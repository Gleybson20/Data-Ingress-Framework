# .env.example
# -------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is listed in .gitignore.
#
#   cp .env.example .env

# ─── Google Cloud ──────────────────────────────────────────────────────────
# Your GCP project ID (visible in the GCP console, top navigation bar)
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket names (created by `make tf-apply`)
GCS_BUCKET_BRONZE=your-gcp-project-id-bronze-raw
GCS_BUCKET_SILVER=your-gcp-project-id-silver-processed
GCS_BUCKET_GOLD=your-gcp-project-id-gold-exports

# BigQuery dataset names (created by `make tf-apply`)
BQ_DATASET_BRONZE=bronze
BQ_DATASET_SILVER=silver
BQ_DATASET_GOLD=gold

# Path to a GCP service account key JSON file (for local development only).
# In CI/CD, Workload Identity Federation is used instead — no key file needed.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# ─── Pipeline behaviour ────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── OAuth2 (for future protected API connectors) ──────────────────────────
# Leave blank if you are only using the public connectors (Open-Meteo, Frankfurter)
OAUTH2_TOKEN_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_SCOPE=

# ─── Notifications ─────────────────────────────────────────────────────────
# Slack incoming webhook URL for pipeline failure alerts
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
